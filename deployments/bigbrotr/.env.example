# ============================================================================
# BigBrotr Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values below.
#
#   cp .env.example .env && nano .env
#
# Generate secure passwords with: openssl rand -base64 32
# Generate a Nostr key with:      openssl rand -hex 32
# ============================================================================

# --- Database passwords (REQUIRED) ------------------------------------------
# Each role has a dedicated password for privilege isolation.
# All five passwords MUST be different.
DB_ADMIN_PASSWORD=
DB_WRITER_PASSWORD=
DB_REFRESHER_PASSWORD=
DB_READER_PASSWORD=
DB_RANKER_PASSWORD=

# --- Nostr private keys (OPTIONAL, recommended for stable identities) -------
# Hex-encoded secp256k1 keys (64 characters) or nsec1 bech32.
# Leave blank to let the service config generate an ephemeral key once at startup.
NOSTR_PRIVATE_KEY_MONITOR=
NOSTR_PRIVATE_KEY_SYNCHRONIZER=
NOSTR_PRIVATE_KEY_DVM=
NOSTR_PRIVATE_KEY_ASSERTOR=

# --- Grafana (REQUIRED) -----------------------------------------------------
GRAFANA_PASSWORD=

# --- Metrics ports (optional) ------------------------------------------------
# Override the host-side port for each service's Prometheus /metrics endpoint.
# Defaults: 800x range. Containers always listen on port 8000 internally.
# FINDER_METRICS_PORT=8001
# VALIDATOR_METRICS_PORT=8002
# MONITOR_METRICS_PORT=8003
# SYNCHRONIZER_METRICS_PORT=8004
# REFRESHER_METRICS_PORT=8005
# RANKER_METRICS_PORT=8009
# API_METRICS_PORT=8006
# DVM_METRICS_PORT=8007
# ASSERTOR_METRICS_PORT=8008
